{
  "manifest_version": 3,
  "name": "staySync 연결 도우미",
  "version": "0.1.0",
  "description": "내 숙박 플랫폼(33m2·자리톡·엔코스테이·리브애니웨어·직방) 로그인 세션을 staySync에 안전하게 연결해 예약을 통합 관리합니다.",
  "permissions": ["cookies", "storage", "tabs", "scripting"],
  "host_permissions": [
    "https://web.33m2.co.kr/*",
    "https://host.enko.kr/*",
    "https://m.liveanywhere.me/*",
    "https://www.liveanywhere.me/*",
    "https://zaritalk.com/*",
    "https://*.zaritalk.com/*",
    "https://www.zigbang.com/*",
    "https://*.zigbang.com/*",
    "http://localhost:3000/*",
    "http://localhost:8000/*",
    "https://app.staysync.kr/*",
    "https://api.staysync.kr/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "staySync 연결",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.33m2.co.kr/*",
        "https://host.enko.kr/*",
        "https://m.liveanywhere.me/*",
        "https://www.liveanywhere.me/*",
        "https://zaritalk.com/*",
        "https://www.zigbang.com/*"
      ],
      "js": ["content-token.js", "content-reservations.js"],
      "run_at": "document_idle"
    }
  ]
}
